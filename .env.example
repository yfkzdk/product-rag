# ==============================================================
# 应用配置
# ==============================================================
APP_NAME=Product Knowledge Graph
APP_VERSION=1.0.0
DEBUG=false
DEMO_MODE=true

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ==============================================================
# 数据库配置
# ==============================================================
POSTGRES_URL=postgresql://product_kg:CHANGE_ME@localhost:5432/product_kg
POSTGRES_POOL_SIZE=10

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=product_knowledge
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_METRIC_TYPE=COSINE
MILVUS_NLIST=1024

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Neo4j 配置（可选，不配置则知识图谱功能禁用）
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password

# ==============================================================
# LLM 配置（支持 DeepSeek / Anthropic 等 OpenAI 兼容提供商）
# ==============================================================
LLM_API_KEY=your_api_key_here
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_CHAT=deepseek-chat
LLM_MODEL_LIGHT=deepseek-chat
ANTHROPIC_API_KEY=your_api_key_here

# ==============================================================
# HuggingFace / Embedding 配置
# ==============================================================
HF_ENDPOINT=https://hf-mirror.com
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_MAX_LENGTH=512
EMBEDDING_BATCH_SIZE=32

# BGE 子进程隔离（Windows 下防止 uvicorn segfault）
BGE_SUBPROCESS=false
# 跳过 BGE 模型加载（Demo 模式或离线环境）
SKIP_BGE_MODEL=false

# ==============================================================
# Reranker 配置
# ==============================================================
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_MAX_LENGTH=512
RERANKER_BATCH_SIZE=16

# ==============================================================
# 检索配置
# ==============================================================
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.7
RRF_K=60

# ==============================================================
# 缓存配置
# ==============================================================
CACHE_TTL=3600

# ==============================================================
# CORS 配置
# ==============================================================
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOWED_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOWED_HEADERS=["*"]

# ==============================================================
# 监控配置
# ==============================================================
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO